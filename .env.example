# SharedGround Environment Configuration

# Set to "true" (default) to use the built-in mock agent for stable demos.
# Set to "false" to use a real LLM via the OpenAI-compatible API.
USE_MOCK_AGENT=true

# OpenAI-compatible API settings (only needed when USE_MOCK_AGENT=false)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
